{
  "name": "metascraper",
  "displayName": "metascraper",
  "description": "Strip metadata from media (images, GIFs, videos) before pushing a repo to a public remote",
  "version": "0.1.0",
  "publisher": "NatalieHill",
  "publisherUrl": "https://github.com/natalie-a-1/",
  "icon": "./images/icon.png",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other",
    "Formatters",
    "Visualization"
  ],
  "keywords": [
    "metadata",
    "image",
    "exif",
    "privacy",
    "security",
    "cleanup",
    "images"
  ],
  "resources": {
    "github": {
      "account": "https://github.com/natalie-a-1",
      "repository": "https://github.com/natalie-a-1/Meta-Scraper"
    },
    "documentation": {
      "usage": "https://github.com/natalie-a-1/Meta-Scraper/blob/main/README.md",
      "testing": "https://github.com/natalie-a-1/Meta-Scraper/blob/main/TESTING.md",
      "publishing": "https://github.com/natalie-a-1/Meta-Scraper/blob/main/PUBLISHING.md"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/natalie-a-1/Meta-Scraper.git"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "metascraper.stripFolder",
        "title": "Strip Metadata from All Media in Folder",
        "category": "MetaScraper"
      },
      {
        "command": "metascraper.cleanMetadata",
        "title": "Strip Media Metadata",
        "category": "MetaScraper"
      },
      {
        "command": "metascraper.viewMetadata",
        "title": "View Media Metadata",
        "category": "MetaScraper"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "metascraper.stripFolder",
          "when": "workbenchState != empty"
        },
        {
          "command": "metascraper.cleanMetadata",
          "when": "false"
        },
        {
          "command": "metascraper.viewMetadata",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "metascraper.stripFolder",
          "when": "explorerResourceIsFolder",
          "group": "metascraper"
        },
        {
          "command": "metascraper.cleanMetadata",
          "when": "resourceExtname =~ /\\.(jpg|jpeg|png|gif|tif|tiff|webp|heic|heif|bmp|mp4|mov|m4v)$/i",
          "group": "metascraper"
        },
        {
          "command": "metascraper.viewMetadata",
          "when": "resourceExtname =~ /\\.(jpg|jpeg|png|gif|tif|tiff|webp|heic|heif|bmp|mp4|mov|m4v)$/i",
          "group": "metascraper"
        }
      ]
    },
    "configuration": {
      "title": "MetaScraper",
      "properties": {
        "metascraper.autoDetectNewMedia": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Automatically detect newly added media in the folder. Only active in workspaces whose Git repository has a remote origin (i.e. repos that can be pushed online)."
        },
        "metascraper.onNewMedia": {
          "type": "string",
          "enum": [
            "strip",
            "ask",
            "nothing"
          ],
          "enumDescriptions": [
            "Automatically strip metadata",
            "Ask for permission",
            "Do nothing"
          ],
          "default": "ask",
          "markdownDescription": "What to do when new media is added (requires `#metascraper.autoDetectNewMedia#`)."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.98.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.21.0"
  },
  "dependencies": {
    "exiftool-vendored": "^29.2.0"
  }
}
